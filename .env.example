# Dodo Payments
# Leave blank to use demo mode. Use live_mode only with real Dodo production credentials.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_RETURN_URL=https://dodolaunch-india.vercel.app

# Solana
# Mainnet-ready by default. Use a production RPC later if volume grows.
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_PUBLIC_KEY=
